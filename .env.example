# Database — Supabase (PostgreSQL). Get from Dashboard: Connect → Connection string. Replace [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase (for same project as DATABASE_URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# Google OAuth (for Calendar)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth (JWT)
JWT_SECRET=change-this-to-a-random-secret-in-production

# URLs (for OAuth redirect and CORS). Dev: frontend 5173, API 3001
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3001

# Production: set when frontend is on Vercel and API is elsewhere (e.g. Railway).
# VITE_API_URL=https://your-api.railway.app

# Optional: port for API server (default 3001)
# PORT=3001
